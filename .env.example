# ============================================================
# LegalSearch Agent - 环境变量模板
# 复制本文件为 .env 后填入实际值。.env 已被 .gitignore 忽略，
# ============================================================

# ------------------------------------------------------------
# LLM API Keys (任选其一或多个，按需在 UI 中切换使用有填写密钥的模型才能使用)
# ------------------------------------------------------------
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DASHSCOPE_API_KEY=your-dashscope-api-key-here
ZHIPUAI_API_KEY=your-zhipuai-api-key-here

# 可选：第三方 Reranker API (若使用云端 reranker)
RERANKER_API_KEY=your-reranker-api-key-here

# ------------------------------------------------------------
# Query 重构模型 (用于将用户口语化提问改写为专业法律表述)
# ------------------------------------------------------------
REWRITE_MODEL=qwen-max
REWRITE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
REWRITE_API_KEY=your-rewrite-api-key-here

# ------------------------------------------------------------
# 本地模型路径 (Embedding / Reranker)
# 留空则从 HuggingFace Hub 自动下载，例如 BAAI/bge-m3
# ------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL_PATH=BAAI/bge-reranker-v2-m3
MODEL_CACHE_DIR=./model_cache/hub
HF_ENDPOINT=https://hf-mirror.com

# ------------------------------------------------------------
# 向量数据库存储路径 (相对或绝对路径均可)
# ------------------------------------------------------------
VECTOR_CASE_DB_PATH=./law_faiss_case
VECTOR_LP_DB_PATH=./law_faiss_lp
VECTOR_GUIDANCE_DB_PATH=./law_faiss_guidance
GUIDANCE_RECORDS_PATH=./knowledge_base_guidance/records
VECTOR_QA_DB_PATH=./law_faiss_qa
QA_RECORDS_PATH=./knowledge_base_qa/records

# ------------------------------------------------------------
# 知识库子目录 (放置原始 JSON / TXT / PDF 等语料)
# ------------------------------------------------------------
CASE_KB_SUBDIR=candidate_folder

# ------------------------------------------------------------
# 应用层配置
# ------------------------------------------------------------
DATABASE_URL=sqlite:///./data/user.db
DEMO_USER_PASSWORD=change-me-on-first-run
